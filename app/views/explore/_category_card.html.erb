<%# Partial: Category/Genre card %>
<%# Locals: category (hash with :id, :name), icon (string), color_class (string) %>

<% category_inline_colors = {
  "Action" => "rgba(239,68,68,0.15)",
  "Adventure" => "rgba(139,92,246,0.15)",
  "Comedy" => "rgba(245,158,11,0.15)",
  "Drama" => "rgba(236,72,153,0.15)",
  "Fantasy" => "rgba(59,130,246,0.15)",
  "Horror" => "rgba(220,38,38,0.15)",
  "Mystery" => "rgba(99,102,241,0.15)",
  "Romance" => "rgba(244,114,182,0.15)",
  "Sci-Fi" => "rgba(6,182,212,0.15)",
  "Slice of Life" => "rgba(16,185,129,0.15)",
  "Sports" => "rgba(34,197,94,0.15)",
  "Thriller" => "rgba(168,85,247,0.15)",
  "Tragedy" => "rgba(190,18,60,0.15)",
  "Mecha" => "rgba(107,114,128,0.15)",
  "Supernatural" => "rgba(124,58,237,0.15)",
  "Psychological" => "rgba(217,70,239,0.15)",
  "Historical" => "rgba(180,83,9,0.15)",
  "Boys' Love" => "rgba(59,130,246,0.15)",
  "Girls' Love" => "rgba(168,85,247,0.15)",
  "Crime" => "rgba(239,68,68,0.15)",
  "Medical" => "rgba(20,184,166,0.15)",
  "Magical Girls" => "rgba(244,114,182,0.15)",
  "Philosophical" => "rgba(107,114,128,0.15)",
  "Music" => "rgba(245,158,11,0.15)",
  "Wuxia" => "rgba(220,38,38,0.15)",
  "Survival" => "rgba(34,197,94,0.15)"
}
bg_color = category_inline_colors[category[:name]] || "rgba(139,92,246,0.15)"
border_color = bg_color.gsub("0.15", "0.35")
%>

<%= link_to explore_category_path(tag_id: category[:id], name: category[:name]),
    class: "category-card",
    style: "background: #{bg_color}; border: 1px solid #{border_color};" do %>
  <div class="category-card__icon"><%= icon %></div>
  <h3 class="category-card__name"><%= category[:name] %></h3>
<% end %>
